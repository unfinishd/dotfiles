{
  "model": "opus[1m]",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${TMUX_AGENT_INDICATOR_DIR:-$HOME/.tmux/plugins/tmux-agent-indicator}\"/scripts/agent-state.sh --agent claude --state needs-input"
          },
          {
            "type": "command",
            "command": "if command -v afplay >/dev/null; then afplay /System/Library/Sounds/Purr.aiff; fi"
          },
          {
            "type": "command",
            "command": "if command -v osascript >/dev/null; then osascript -e 'display notification \"Claude Code needs your attention\" with title \"Claude Code\"'; else printf '\\a'; fi"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x \"$HOME/.local/bin/island-agent-hook\" ]; then ISLAND_HOOK_AGENT=claude ISLAND_HOOK_HOST_KIND=host \"$HOME/.local/bin/island-agent-hook\"; fi"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x \"$HOME/.local/bin/island-agent-hook\" ]; then ISLAND_HOOK_AGENT=claude ISLAND_HOOK_HOST_KIND=host \"$HOME/.local/bin/island-agent-hook\"; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x \"$HOME/.local/bin/island-agent-hook\" ]; then ISLAND_HOOK_AGENT=claude ISLAND_HOOK_HOST_KIND=host \"$HOME/.local/bin/island-agent-hook\"; fi"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x \"$HOME/.local/bin/island-agent-hook\" ]; then ISLAND_HOOK_AGENT=claude ISLAND_HOOK_HOST_KIND=host \"$HOME/.local/bin/island-agent-hook\"; fi"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x \"$HOME/.local/bin/island-agent-hook\" ]; then ISLAND_HOOK_AGENT=claude ISLAND_HOOK_HOST_KIND=host \"$HOME/.local/bin/island-agent-hook\"; fi"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.tmux/plugins/tmux-assistant-resurrect/hooks/claude-session-cleanup.sh\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x \"$HOME/.local/bin/island-agent-hook\" ]; then ISLAND_HOOK_AGENT=claude ISLAND_HOOK_HOST_KIND=host \"$HOME/.local/bin/island-agent-hook\"; fi"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.tmux/plugins/tmux-assistant-resurrect/hooks/claude-session-track.sh\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x \"$HOME/.local/bin/island-agent-hook\" ]; then ISLAND_HOOK_AGENT=claude ISLAND_HOOK_HOST_KIND=host \"$HOME/.local/bin/island-agent-hook\"; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${TMUX_AGENT_INDICATOR_DIR:-$HOME/.tmux/plugins/tmux-agent-indicator}\"/scripts/agent-state.sh --agent claude --state done"
          },
          {
            "type": "command",
            "command": "if command -v afplay >/dev/null; then afplay /System/Library/Sounds/Funk.aiff; fi"
          },
          {
            "type": "command",
            "command": "if command -v osascript >/dev/null; then osascript -e 'display notification \"Claude Code has finished\" with title \"Claude Code\"'; else printf '\\a'; fi"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x \"$HOME/.local/bin/island-agent-hook\" ]; then ISLAND_HOOK_AGENT=claude ISLAND_HOOK_HOST_KIND=host \"$HOME/.local/bin/island-agent-hook\"; fi"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"${TMUX_AGENT_INDICATOR_DIR:-$HOME/.tmux/plugins/tmux-agent-indicator}\"/scripts/agent-state.sh --agent claude --state running"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x \"$HOME/.local/bin/island-agent-hook\" ]; then ISLAND_HOOK_AGENT=claude ISLAND_HOOK_HOST_KIND=host \"$HOME/.local/bin/island-agent-hook\"; fi"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "theme": "dark-ansi",
  "preferredNotifChannel": "ghostty"
}
